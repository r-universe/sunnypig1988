[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "BCSub"]
	path = BCSub
	url = https://github.com/cran/BCSub
	shallow = true
	registered = true
[submodule "dcGSA"]
	path = dcGSA
	url = https://git.bioconductor.org/packages/dcGSA
	shallow = true
	registered = true
